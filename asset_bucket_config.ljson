{
    version: 1
    rootDirectory: asset_bucket

    excludeAllPaths: [
        *.md
    ]
    
    buckets: [
        {
            name: bucketBackgrounds
            macroScript: __bucketBackgrounds
        }
    ]
    
    datafiles: []
    
    sprites: [
        {
            include: {
                path: *.png
                width: >100
            }
            action: {
                importBucket: bucketBackgrounds
            }
        }
    ]
    
    sounds: []
}