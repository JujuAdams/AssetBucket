function __BucketClassWAVDescriptor(_originalPath, _bitsPerSample, _sampleRate, _offset, _bytes, _channels) constructor
{
    __originalPath  = _originalPath;
    __bitsPerSample = _bitsPerSample;
    __sampleRate    = _sampleRate;
    __offset        = _offset;
    __bytes         = _bytes;
    __channels      = _channels;
}