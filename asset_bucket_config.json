{
    "version": 1,
    "rootDirectory": "asset_bucket",

    "buckets": [
        {
            "name": "bucketDefault",
            "textureFormat": "zlib",
        },
    ],

    "tasks": [
        {
            "include": {
                "path": "datafiles/*",
            },
            "worker": {
                "resourceType": "datafile",
                "function": "importToBucket",
                "bucket": "bucketDefault"
            },
        },
        {
            "include": {
                "path": ["sprites/*.png", "sprites/*.psd"],
            },
            "worker": {
                "resourceType": "sprite",
                "function": "importToBucket",
                "bucket": "bucketDefault"
                //"folder": "Sprites/",
                //"textureGroup": "Default",
            },
        },
        {
            "include": {
                "path": ["sounds/*.wav", "sounds/*.ogg"],
            },
            "worker": {
                "resourceType": "sound",
                "function": "importToBucket",
                "bucket": "bucketDefault"
                //"folder": "Sounds/",
                //"audioGroup": "audiogroup_default",
            },
        },
    ],
}