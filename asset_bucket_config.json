{
    "version": 1,
    "rootDirectory": "asset_bucket",

    "buckets": [
        {
            "name": "bucketDefault",
        },
    ],

    "tasks": [
        {
            "include": {
                "path": "datafiles/*",
            },
            "worker": {
                "name": "defaultToBucket",
                "type": "datafile",
                "bucket": "bucketDefault"
            },
        },
        {
            "include": {
                "path": "sprites/*",
            },
            "worker": {
                "name": "defaultToProject",
                "type": "sprite",
                "folder": "Sprites/Asset Bucket/",
                "textureGroup": "Default",
            },
        },
        {
            "include": {
                "path": ["sounds/*.wav", "sounds/*.ogg"],
            },
            "worker": {
                "name": "defaultToProject",
                "type": "sound",
                "folder": "Sounds/Asset Bucket/",
                "audioGroup": "audiogroup_default",
            },
        },
    ],
}