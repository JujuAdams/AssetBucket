{
    "version": 1,
    "rootDirectory": "asset_bucket",

    "buckets": [
        {
            "name": "bucketDefault",
        },
    ],

    "tasks": [
        {
            "include": {
                "path": "datafiles/*",
            },
            "worker": {
                "resourceType": "datafile",
                "name": "importToBucket",
                "bucket": "bucketDefault"
            },
        },
        {
            "include": {
                "path": "sprites/*.png",
            },
            "worker": {
                "resourceType": "sprite",
                "name": "importToBucket",
                "bucket": "bucketDefault",
            },
        },
