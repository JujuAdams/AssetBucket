{
    "version": 1,
    "rootDirectory": "asset_bucket",

    "buckets": [
        {
            "name": "bucketDefault",
        },
    ],

    "tasks": [
        {
            "include": {
                "path": "datafiles/*",
            },
            "worker": {
                "resourceType": "datafile",
                "name": "importToBucket",
                "bucket": "bucketDefault"
            },
        },
        //{
        //    "include": {
        //        "path": "sprites/*.png",
        //    },
        //    "worker": {
        //        "resourceType": "sprite",
        //        "name": "importToProject",
        //        "folder": "Sprites/",
        //        "textureGroup": "Default",
        //    },
        //},
        {
            "include": {
                "path": "sounds/*.wav",
            },
            "worker": {
                "resourceType": "sound",
                "name": "importToBucket",
                "bucket": "bucketDefault",
                "compress": false,
            },
        },
    ],
}